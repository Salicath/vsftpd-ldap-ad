listen=YES
listen_ipv6=NO

anonymous_enable=NO
local_enable=YES
write_enable=YES
local_umask=022

guest_enable=YES
guest_username=ftpuser
local_root=/home/vsftpd

pam_service_name=vsftpd

chroot_local_user=YES
allow_writeable_chroot=YES

# Don't do reverse uid→name lookups via NSS in listings; avoids
# extra LDAP round-trips and a code path that has crashed on teardown.
text_userdb_names=NO
check_shell=NO

seccomp_sandbox=NO
secure_chroot_dir=/var/run/vsftpd/empty

pasv_enable=YES
pasv_address=${PASV_ADDRESS}
pasv_min_port=${PASV_MIN_PORT}
pasv_max_port=${PASV_MAX_PORT}

xferlog_enable=NO
