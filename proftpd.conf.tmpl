Include /etc/proftpd/modules.conf
# Debian ships both mod_ldap and mod_tls as separate packages and leaves
# them commented out in modules.conf; force-load both so <IfModule> blocks
# further down actually fire.
LoadModule            mod_ldap.c
LoadModule            mod_tls.c

ServerName            "ftp-ldap"
ServerType            standalone
DefaultServer         on
Port                  21
Umask                 022
MaxInstances          10

User                  ftpuser
Group                 ftpuser

# Chroot every session here, regardless of the user's nominal home dir.
DefaultRoot           /srv/ftp

AllowOverwrite        on
AllowStoreRestart     on
RequireValidShell     off

# Passive mode: range matches the Quadlet's PublishPort, advertised address
# is the IP the FTP client uses to reach this host.
PassivePorts          ${PASV_MIN_PORT} ${PASV_MAX_PORT}
MasqueradeAddress     ${PASV_ADDRESS}

# ProFTPD refuses symlinks for SystemLog; 'none' disables file logging
# (container is ephemeral anyway; use `podman exec` to inspect if needed).
SystemLog             none
TransferLog           none

<IfModule mod_ldap.c>
  # RFC 4516 URL with '/??sub' forces subtree scope; without it mod_ldap
  # may fall back to a base-only search that returns nothing.
  LDAPServer          ldap://${AD_HOST}/??sub
  LDAPBindDN          "${AD_BIND_DN}" "${AD_BIND_PW}"
  LDAPAuthBinds       on
  LDAPSearchScope     subtree

  # NB: AD referral chasing (which causes search timeouts) is disabled
  # system-wide via /etc/ldap/ldap.conf 'REFERRALS off' — see Containerfile.
  # ProFTPD itself has no directive for it.

  # The access-control line: only AD users in the target group match.
  # Third filter (uid-number) is required for syntactic completeness even
  # though LDAPForceDefaultUID means it's never actually queried.
  # For nested groups, swap memberOf= for memberOf:1.2.840.113556.1.4.1941:=
  LDAPUsers           "${AD_BASE_DN}" "(&(objectClass=user)(sAMAccountName=%u)(memberOf=${AD_GROUP_DN}))" "(&(objectClass=user)(uidNumber=%v))"

  # AD stores usernames in sAMAccountName and has no POSIX gidNumber;
  # map both so mod_ldap can parse the record as a user. primaryGroupID
  # is always 513 on domain users and is thrown away by LDAPForceDefaultGID.
  LDAPAttr            uid sAMAccountName
  LDAPAttr            gidNumber primaryGroupID

  # Force every authenticated user to the local ftpuser identity (uid 1000).
  LDAPDefaultUID      1000
  LDAPDefaultGID      1000
  LDAPForceDefaultUID on
  LDAPForceDefaultGID on

  # Synthesize a home-directory path so ProFTPD is happy; DefaultRoot above
  # overrides the actual chroot location.
  LDAPGenerateHomedir on
  LDAPGenerateHomedirPrefix /srv/ftp
  LDAPGenerateHomedirPrefixNoUsername on
</IfModule>

AuthOrder             mod_ldap.c
