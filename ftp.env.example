# ftp-ldap environment file.
# Copy to ~/ftp.env and edit if your network differs from the defaults.
#
# On exam day / when the lab moves, the ONLY values you usually need to
# change are AD_HOST and PASV_ADDRESS (the last lines below). Everything
# else depends on AD structure, not network topology.

# ---- Active Directory connection ----
# The IP or hostname of the domain controller. Change this when the lab
# network changes.
AD_HOST=192.168.1.21

# The DN of the AD domain. For h3.local this is DC=h3,DC=local.
AD_BASE_DN=DC=h3,DC=local

# The read-only service account used to search LDAP. A normal unprivileged
# domain user account is enough — do NOT use a Domain Admin.
AD_BIND_DN=CN=svc-ldap,OU=Servicekonti,DC=h3,DC=local
AD_BIND_PW=Kode1234!

# The exact distinguishedName of the AD group whose members may log in.
# Copy this from Active Directory Users and Computers → the group →
# Attribute Editor → distinguishedName.
AD_GROUP_DN=CN=FTP-Brugere,OU=Sikkerhedsgrupper,DC=h3,DC=local

# ---- Passive FTP ----
# PASV_ADDRESS is the IP this host is reachable on from the FTP clients.
# Change this when the lab network changes.
PASV_ADDRESS=192.168.1.13
PASV_MIN_PORT=50000
PASV_MAX_PORT=50100

# ---- Optional FTPS ----
# Set YES to enable TLS. Auto-generates a self-signed cert unless one is
# mounted at /etc/proftpd/ssl/proftpd.pem via the Quadlet.
# Clients must use explicit FTPS (AUTH TLS) — plain FTP is rejected.
FTPS_ENABLE=NO
