AD_HOST=192.168.1.21
AD_BASE_DN=DC=h3,DC=local
AD_BIND_DN=CN=svc-ldap,OU=Servicekonti,DC=h3,DC=local
AD_BIND_PW=Kode1234!

AD_GROUP_DN=CN=FTP-Brugere,OU=Sikkerhedsgrupper,DC=h3,DC=local

# IP the FTP client uses to reach this host. Test: 192.168.1.13   Prod: 10.2.80.11
PASV_ADDRESS=192.168.1.13
PASV_MIN_PORT=50000
PASV_MAX_PORT=50100

# Set YES to enable FTPS (TLS). Auto-generates a self-signed cert unless
# one is mounted at /etc/vsftpd/vsftpd.pem via the Quadlet.
# Clients must use explicit FTPS (AUTH TLS) after this — plain FTP rejected.
FTPS_ENABLE=NO
